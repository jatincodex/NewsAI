# =============================================================
# NewsAI Environment Variables
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to .env  (no dot at start is fine too)
#   2. Fill in your Firebase credentials below
#   3. The server auto-loads this file on startup
#   4. NEVER commit .env to GitHub (it's in .gitignore)
# =============================================================

# ---------------------------------------------------------
# OPTION A (EASIEST): Paste your entire Firebase JSON key
# ---------------------------------------------------------
# 1. Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download .json file
# 3. Open the file in Notepad, copy ALL content
# 4. Paste it below as a single line (keep the quotes)
# ---------------------------------------------------------
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@YOUR_PROJECT_ID.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ---------------------------------------------------------
# OPTION B: Individual variables (alternative to Option A)
# ---------------------------------------------------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ---------------------------------------------------------
# Gemini API Key (for AI fact-checking)
# ---------------------------------------------------------
# GEMINI_API_KEY=your_gemini_api_key_here
